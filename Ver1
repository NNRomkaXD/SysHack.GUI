local Flight = {
    Enabled = false,
    Speed = 100,
    BodyVelocity = nil,
    BodyGyro = nil,
    Connection = nil
}

local function getDirection()
    local cam = workspace.CurrentCamera.CFrame
    local move = Vector3.new(0, 0, 0)
    
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        move = move + cam.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        move = move - cam.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
        move = move - cam.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
        move = move + cam.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        move = move + Vector3.new(0, 1, 0)
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        move = move - Vector3.new(0, 1, 0)
    end
    
    if move.Magnitude > 0 then
        move = move.Unit
    end
    
    return move
end

local function toggleFlight()
    Flight.Enabled = not Flight.Enabled
    
    if Flight.Enabled then        
        local character = LocalPlayer.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")
        if not root then Flight.Enabled = false return end
        
        Flight.BodyVelocity = Instance.new("BodyVelocity")
        Flight.BodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        Flight.BodyVelocity.Velocity = Vector3.new(0, 0, 0)
        Flight.BodyVelocity.Parent = root
        
        Flight.BodyGyro = Instance.new("BodyGyro")
        Flight.BodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        Flight.BodyGyro.P = 10000
        Flight.BodyGyro.D = 500
        Flight.BodyGyro.CFrame = root.CFrame
        Flight.BodyGyro.Parent = root
        
        Flight.Connection = RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            
            if hrp and hum and Flight.Enabled then
                local dir = getDirection()
                local cam = workspace.CurrentCamera
                
                Flight.BodyVelocity.Velocity = dir * Flight.Speed
                Flight.BodyGyro.CFrame = cam.CFrame
                hum:ChangeState(Enum.HumanoidStateType.Physics)
            elseif not Flight.Enabled then
                if Flight.Connection then Flight.Connection:Disconnect() end
            end
        end)
    else
        if Flight.Connection then Flight.Connection:Disconnect() end
        if Flight.BodyVelocity then Flight.BodyVelocity:Destroy() end
        if Flight.BodyGyro then Flight.BodyGyro:Destroy() end
        
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end
end

LocalPlayer.CharacterAdded:Connect(function()
    if Flight.Enabled then
        toggleFlight()
    end
end)

local Hitbox = {
    Enabled = true,
    Size = 1000,
    Transparency = 1
}

local function applyHitbox(character)
    local hrp = character:WaitForChild("HumanoidRootPart", 10)
    if hrp and Hitbox.Enabled then
        hrp.Size = Vector3.new(Hitbox.Size, Hitbox.Size, Hitbox.Size)
        hrp.Transparency = Hitbox.Transparency
        hrp.CanCollide = false
    end
end

local function setupHitboxPlayer(player)
    if player ~= LocalPlayer then
        player.CharacterAdded:Connect(applyHitbox)
        if player.Character then
            applyHitbox(player.Character)
        end
    end
end

Players.PlayerAdded:Connect(setupHitboxPlayer)
for _, player in ipairs(Players:GetPlayers()) do
    setupHitboxPlayer(player)
end

local Invisible = {
    Enabled = true,
    Active = false,
    Transparency = 0.75,
    SeatPos = Vector3.new(-25.95, 400, 3537.55),
    VoidY = -50,
    Connection = nil,
    CurrentSeat = nil
}

local function setCharacterTransparency(transparency)
    local character = LocalPlayer.Character
    if character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Transparency = transparency
            end
        end
    end
end

local function stopInvisHeartbeat()
    if Invisible.Connection then
        Invisible.Connection:Disconnect()
        Invisible.Connection = nil
    end
end

local function toggleInvisibility()
    if not Invisible.Enabled then return end
    
    Invisible.Active = not Invisible.Active
    local character = LocalPlayer.Character
    if not character then return end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end

    if Invisible.Active then
        setCharacterTransparency(Invisible.Transparency)
        local savedpos = humanoidRootPart.CFrame
        
        task.wait(0.05)
        pcall(function() character:MoveTo(Invisible.SeatPos) end)
        task.wait(0.05)

        if humanoidRootPart.Position.Y < Invisible.VoidY then
            pcall(function() character:MoveTo(savedpos.Position) end)
            Invisible.Active = false
            setCharacterTransparency(0)
            return
        end

        local Seat = Instance.new('Seat')
        Seat.Parent = workspace
        Seat.Anchored = false
        Seat.CanCollide = false
        Seat.Name = 'invischair'
        Seat.Transparency = 1
        Seat.Position = Invisible.SeatPos

        local Weld = Instance.new("Weld")
        Weld.Part0 = Seat
        local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
        
        if torso then
            Weld.Part1 = torso
            Weld.Parent = Seat
            task.wait()
            pcall(function() Seat.CFrame = savedpos end)
            Invisible.CurrentSeat = Seat.Position
        else
            Seat:Destroy()
            Invisible.CurrentSeat = nil
            stopInvisHeartbeat()
        end
    else
        setCharacterTransparency(0)
        task.spawn(function()
            local inv = workspace:FindFirstChild('invischair')
            if inv then
                pcall(function() inv:Destroy() end)
            end
        end)
        stopInvisHeartbeat()
        Invisible.CurrentSeat = nil
    end
end

local Noclip = {
    Enabled = true,
    Connection = nil
}

local function toggleNoclip()
    Noclip.Enabled = not Noclip.Enabled
    
    if Noclip.Enabled then
        Noclip.Connection = RunService.Stepped:Connect(function()
            if LocalPlayer.Character then
                for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    else
        if Noclip.Connection then Noclip.Connection:Disconnect() end
    end
end

local Physics = {
    Speed = 16,
    JumpPower = 50,
    Gravity = 196.2,
    Mode = "WS",
    BodyVelocity = nil
}

local function updatePhysicsStats()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local hum = LocalPlayer.Character.Humanoid
        hum.JumpPower = Physics.JumpPower
        if Physics.Mode == "BV" then
            hum.WalkSpeed = 16
        else
            hum.WalkSpeed = Physics.Speed
        end
    end
    workspace.Gravity = Physics.Gravity
end

local function togglePhysicsMode()
    Physics.Mode = (Physics.Mode == "WS" and "BV" or "WS")
    updatePhysicsStats()
end

local function setupPhysics(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end
    if hrp:FindFirstChild("MovementBV") then hrp.MovementBV:Destroy() end
    
    Physics.BodyVelocity = Instance.new("BodyVelocity")
    Physics.BodyVelocity.Name = "MovementBV"
    Physics.BodyVelocity.MaxForce = Vector3.zero
    Physics.BodyVelocity.Velocity = Vector3.zero
    Physics.BodyVelocity.Parent = hrp
    
    task.wait(0.1)
    updatePhysicsStats()
end

if LocalPlayer.Character then task.spawn(setupPhysics, LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(setupPhysics)

RunService.RenderStepped:Connect(function()
    if not (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") and Physics.BodyVelocity and Physics.BodyVelocity.Parent) then return end
    
    local moveDir = LocalPlayer.Character.Humanoid.MoveDirection
    
    if Physics.Mode == "BV" then
        Physics.BodyVelocity.MaxForce = Vector3.new(1e6, 0, 1e6)
        if moveDir.Magnitude > 0 then
            Physics.BodyVelocity.Velocity = moveDir * Physics.Speed
        else
            Physics.BodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    else
        Physics.BodyVelocity.MaxForce = Vector3.zero
        Physics.BodyVelocity.Velocity = Vector3.zero
    end
end)

updatePhysicsStats()

