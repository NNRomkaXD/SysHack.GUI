            if not (pos.X >= absPos.X and pos.X <= absPos.X + absSize.X and
                    pos.Y >= absPos.Y and pos.Y <= absPos.Y + absSize.Y) and
               not (pos.X >= menuPos.X and pos.X <= menuPos.X + menuSize.X and
                    pos.Y >= menuPos.Y and pos.Y <= menuPos.Y + menuSize.Y) then
                menu.Visible = false
            end
        end
    end)
    
    return frame
end

