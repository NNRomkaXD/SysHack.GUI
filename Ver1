    label.Font = Enum.Font.SourceSans
    label.TextSize = 15
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local box = Instance.new("TextBox", frame)
    box.Size = UDim2.new(0.5, -15, 1, -6)
    box.Position = UDim2.new(0.5, 5, 0, 3)
    box.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    box.TextColor3 = Color3.new(1, 1, 1)
    box.Font = Enum.Font.SourceSans
    box.TextSize = 14
    box.Text = ""
    box.PlaceholderText = tostring(Config[prop]) .. (suffix and " " .. suffix or "")
    box.PlaceholderColor3 = Color3.fromRGB(150, 150, 150)
    box.ClearTextOnFocus = true
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
    
    box.FocusLost:Connect(function()
        local text = box.Text:gsub("%s+", "")
        if text == "" then
            box.Text = ""
            box.PlaceholderText = tostring(Config[prop]) .. (suffix and " " .. suffix or "")
            return
        end
        local num = tonumber(text)
        if num then
            Config[prop] = num
            box.Text = ""
            box.PlaceholderText = tostring(num) .. (suffix and " " .. suffix or "")
        else
            box.Text = ""
            box.PlaceholderText = tostring(Config[prop]) .. (suffix and " " .. suffix or "")
        end
    end)
end

