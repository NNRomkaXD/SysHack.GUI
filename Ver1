        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            if hum then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end
end)

UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.Z then
        Config.Invis_Enabled = not Config.Invis_Enabled
        toggleInvis(Config.Invis_Enabled)
        if updateInvis then updateInvis() end
    elseif i.KeyCode == Enum.KeyCode.Insert then
        Main.Visible = not Main.Visible
    end
end)

local updateInvis
for _, v in pairs(CharacterScroll:GetChildren()) do
    if v:IsA("TextButton") and v:FindFirstChild("TextLabel") and v.TextLabel.Text == "Invisible" then
        local indicator = v:FindFirstChild("Frame")
        if indicator then
            updateInvis = function()
                indicator.BackgroundColor3 = Config.Invis_Enabled and Color3.fromRGB(100, 200, 100) or Color3.fromRGB(60, 60, 60)
            end
        end
        break
    end
end

