            if Config.TeleportMode == "All" then
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character then
                        local tRoot = player.Character:FindFirstChild("HumanoidRootPart")
                        if tRoot then tRoot.CFrame = CFrame.new(offsetPosition) end
                    end
                end
            elseif Config.TeleportMode == "Target" and Config.TeleportTarget ~= "" then
                local target = Players:FindFirstChild(Config.TeleportTarget)
                if target and target.Character then
                    local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
                    if tRoot then tRoot.CFrame = CFrame.new(offsetPosition) end
                end
            end
        end)
    else
        if teleportConnection then teleportConnection:Disconnect() teleportConnection = nil end
    end
end)
