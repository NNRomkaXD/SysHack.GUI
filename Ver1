UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == GUI.ToggleKey then
        local gui = LocalPlayer:FindFirstChild("PlayerGui"):FindFirstChild("CheatMenu")
        if gui then
            gui:Destroy()
        else
            createGUI()
        end
    end
    if input.KeyCode == Enum.KeyCode.Z then
        toggleInvisibility()
    end
end)

if GUI.Enabled then
    createGUI()
end

toggleNoclip()
