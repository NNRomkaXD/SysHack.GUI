            box.PlaceholderText = string.format("%.0f %.0f %.0f", Config[prop].X, Config[prop].Y, Config[prop].Z)
            return
        end
        local x, y, z = box.Text:match("([%-%d%.]+)%s+([%-%d%.]+)%s+([%-%d%.]+)")
