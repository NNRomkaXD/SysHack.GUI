RunService.Heartbeat:Connect(function(dt)
    local char, hrp, hum = LocalPlayer.Character, LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart"), LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if not (char and hrp and hum) then return end

    local mBV = hrp:FindFirstChild("MoveBV") or Instance.new("BodyVelocity", hrp)
    mBV.Name = "MoveBV"
    mBV.MaxForce = Vector3.zero

    hum.JumpPower = Config.JumpPower
    workspace.Gravity = Config.Gravity

    if Config.BV_Enabled then
        hum.WalkSpeed = 16
        local dir = hum.MoveDirection
        if dir.Magnitude > 0 then
            mBV.MaxForce = Vector3.new(1e6, 0, 1e6)
            mBV.Velocity = dir * Config.BV_Speed
        else mBV.MaxForce = Vector3.zero end
    else
        mBV.MaxForce = Vector3.zero
        hum.WalkSpeed = Config.Speed
    end

    if Config.Noclip then
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    else
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") and not v.CanCollide then v.CanCollide = true end end
    end
end)

RunService.RenderStepped:Connect(function()
    if Config.Hitbox then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
                local head = p.Character.Head
                head.Size = Vector3.one * Config.HitboxSize
                head.Transparency = Config.HitboxVisible and 0.5 or 1
                head.CanCollide = false
                if head:FindFirstChild("Face") then head.Face.Transparency = Config.HitboxVisible and 0.5 or 1 end
                for _, child in pairs(head:GetChildren()) do
                    if child:IsA("Decal") or child:IsA("Texture") then child.Transparency = Config.HitboxVisible and 0.5 or 1 end
                end
            end
        end
    else resetHitboxes() end
end)

UserInputService.JumpRequest:Connect(function()
    if Config.InfJump then
        local char, hum = LocalPlayer.Character, LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)

UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.Z then
        Config.Invis_Enabled = not Config.Invis_Enabled
        toggleInvis(Config.Invis_Enabled)
    elseif i.KeyCode == Enum.KeyCode.Insert then Main.Visible = not Main.Visible end
end)

Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(character)
        task.wait(0.5)
        if not Config.Hitbox and character:FindFirstChild("Head") then
            local head = character.Head
            head.Size = Vector3.new(1.2, 1.2, 1.2)
            head.Transparency = 0
            head.CanCollide = true
            if head:FindFirstChild("Face") then head.Face.Transparency = 0 end
            for _, child in pairs(head:GetChildren()) do
                if child:IsA("Decal") or child:IsA("Texture") then child.Transparency = 0 end
            end
        end
        if Config.DisableRagdoll then task.wait(0.1) toggleRagdoll(true) end
    end)
end)
