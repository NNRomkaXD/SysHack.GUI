    fill.Size = UDim2.new((Config.WalkSpeed - 0) / (500 - 0), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
    fill.BorderSizePixel = 0
    fill.ZIndex = 2
    
    local fillCorner = Instance.new("UICorner", fill)
    fillCorner.CornerRadius = UDim.new(1, 0)
    
    local knob = Instance.new("TextButton", sliderTrack)
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.Position = UDim2.new((Config.WalkSpeed - 0) / (500 - 0), -6, 0.5, -6)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Text = ""
    knob.BorderSizePixel = 0
    knob.ZIndex = 3
    
    local knobCorner = Instance.new("UICorner", knob)
    knobCorner.CornerRadius = UDim.new(1, 0)
    
    local dragging = false
    
    local function updateSpeedUI(value)
        local newValue = math.clamp(value, 0, 500)
        if Config.MovementMode == "WalkSpeed" then
            Config.WalkSpeed = newValue
            speedValue.Text = string.format("%.0f", newValue) .. " s/s"
        else
            Config.BVSpeed = newValue
            speedValue.Text = string.format("%.0f", newValue) .. " s/s"
        end
        local percent = newValue / 500
        fill.Size = UDim2.new(percent, 0, 1, 0)
        knob.Position = UDim2.new(percent, -6, 0.5, -6)
    end
    
    local function updateModeDisplay()
        modeText.Text = Config.MovementMode
        if Config.MovementMode == "WalkSpeed" then
            speedValue.Text = string.format("%.0f", Config.WalkSpeed) .. " s/s"
            local percent = Config.WalkSpeed / 500
            fill.Size = UDim2.new(percent, 0, 1, 0)
            knob.Position = UDim2.new(percent, -6, 0.5, -6)
        else
            speedValue.Text = string.format("%.0f", Config.BVSpeed) .. " s/s"
            local percent = Config.BVSpeed / 500
            fill.Size = UDim2.new(percent, 0, 1, 0)
            knob.Position = UDim2.new(percent, -6, 0.5, -6)
        end
    end
    
    leftArrow.MouseButton1Click:Connect(function()
        if Config.MovementMode == "WalkSpeed" then
            Config.MovementMode = "BodyVelocity"
        else
            Config.MovementMode = "WalkSpeed"
        end
        updateModeDisplay()
    end)
    
    rightArrow.MouseButton1Click:Connect(function()
        if Config.MovementMode == "WalkSpeed" then
            Config.MovementMode = "BodyVelocity"
        else
            Config.MovementMode = "WalkSpeed"
        end
        updateModeDisplay()
    end)
    
    knob.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local mousePos = input.Position.X
            local sliderPos = sliderTrack.AbsolutePosition.X
            local sliderWidth = sliderTrack.AbsoluteSize.X
            local percent = math.clamp((mousePos - sliderPos) / sliderWidth, 0, 1)
            local newValue = percent * 500
            updateSpeedUI(newValue)
        end
    end)
    
    updateModeDisplay()
    
    return modeFrame, speedFrame
end

